NEXT_PUBLIC_APP_URL=https://easecaseinc.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key_here
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=prctbl_optional_pricing_table_id
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_PRICE_ID=price_monthly_199_here
STRIPE_WEBHOOK_SECRET=whsec_webhook_secret_here
STRIPE_TEST_CUSTOMER_ID=cus_optional_for_local_portal_testing
OPENAI_API_KEY=sk-proj_your_openai_key_here
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here
NEXT_PUBLIC_DISABLE_PAYWALL=false

# Persistent user login and subscription status storage.
# Use Vercel KV or Upstash Redis REST credentials so users survive redeploys.
UPSTASH_REDIS_REST_URL=https://your-upstash-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
# If using Vercel KV instead, these are also supported:
KV_REST_API_URL=https://your-vercel-kv-rest-url
KV_REST_API_TOKEN=your_vercel_kv_rest_token
